---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="电竞资讯 - 即将上线">
  <main class="min-h-screen" style="background:#080814;font-family:'Noto Sans SC',sans-serif">
    <div class="max-w-4xl mx-auto px-4 py-16 text-center">
      <a href="/" class="inline-flex items-center gap-2 text-indigo-400 hover:text-indigo-300 mb-8 text-sm">&larr; 返回首页</a>
      <div class="text-6xl mb-6 mt-20">📰</div>
      <h1 class="text-4xl font-black text-white mb-4" style="font-family:Rajdhani,sans-serif">
        电竞<span style="color:#a5b4fc">资讯</span>
      </h1>
      <p class="text-gray-500 text-lg">即将上线，敬请期待</p>
    </div>
  </main>
</BaseLayout>
